# Mony web — local dev environment example.
# Copy to `.env.local` and fill with the real values from your
# Supabase + Stripe dashboards.
#
# Both NEXT_PUBLIC_* values are safe to expose to the browser by
# design — they're either anon credentials gated by RLS or
# Stripe's publishable key (which only mounts the client SDK).
# Server-only secrets (STRIPE_SECRET_KEY, future
# SUPABASE_SERVICE_ROLE_KEY in API routes) MUST stay non-public.

# ─── Supabase ────────────────────────────────────────────────────
# Same anon credentials the mobile app reads from
# EXPO_PUBLIC_SUPABASE_URL / EXPO_PUBLIC_SUPABASE_ANON_KEY.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>

# ─── Stripe (test mode for v1; live keys flip in H.14) ───────────
# Two API keys: secret (server-only) + publishable (client SDK).
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Six Stripe Prices — one per (currency × cadence) combination.
# Create on the Mony Pro product in the Stripe Dashboard:
#   - Mony Pro / monthly recurring / EUR    €19    → STRIPE_PRICE_EUR_MONTHLY
#   - Mony Pro / yearly recurring  / EUR    €190   → STRIPE_PRICE_EUR_YEARLY
#   - Mony Pro / monthly recurring / USD    $19    → STRIPE_PRICE_USD_MONTHLY
#   - Mony Pro / yearly recurring  / USD    $190   → STRIPE_PRICE_USD_YEARLY
#   - Mony Pro / monthly recurring / AED    AED 79  → STRIPE_PRICE_AED_MONTHLY
#   - Mony Pro / yearly recurring  / AED    AED 749 → STRIPE_PRICE_AED_YEARLY
#
# H.8 (revised post-H.7.3) reads NEXT_CURRENCY cookie + cadence
# param and selects the matching env via
# `STRIPE_PRICE_${CURRENCY}_${CADENCE}`.
STRIPE_PRICE_EUR_MONTHLY=price_...
STRIPE_PRICE_EUR_YEARLY=price_...
STRIPE_PRICE_USD_MONTHLY=price_...
STRIPE_PRICE_USD_YEARLY=price_...
STRIPE_PRICE_AED_MONTHLY=price_...
STRIPE_PRICE_AED_YEARLY=price_...

# Webhook secret added in H.9 (Stripe webhook handler).
# STRIPE_WEBHOOK_SECRET=whsec_...
