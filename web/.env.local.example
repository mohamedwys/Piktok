# Mony web — local dev environment example.
# Copy to `.env.local` and fill with the real values from your
# Supabase + Stripe dashboards.
#
# Both NEXT_PUBLIC_* values are safe to expose to the browser by
# design — they're either anon credentials gated by RLS or
# Stripe's publishable key (which only mounts the client SDK).
# Server-only secrets (STRIPE_SECRET_KEY, future
# SUPABASE_SERVICE_ROLE_KEY in API routes) MUST stay non-public.

# ─── Supabase ────────────────────────────────────────────────────
# Same anon credentials the mobile app reads from
# EXPO_PUBLIC_SUPABASE_URL / EXPO_PUBLIC_SUPABASE_ANON_KEY.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>

# ─── Stripe (test mode for v1; live keys flip in H.14) ───────────
# Two API keys: secret (server-only) + publishable (client SDK).
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Six Stripe Prices — one per (currency × cadence) combination.
# Create on the Mony Pro product in the Stripe Dashboard:
#   - Mony Pro / monthly recurring / EUR    €19    → STRIPE_PRICE_EUR_MONTHLY
#   - Mony Pro / yearly recurring  / EUR    €190   → STRIPE_PRICE_EUR_YEARLY
#   - Mony Pro / monthly recurring / USD    $19    → STRIPE_PRICE_USD_MONTHLY
#   - Mony Pro / yearly recurring  / USD    $190   → STRIPE_PRICE_USD_YEARLY
#   - Mony Pro / monthly recurring / AED    AED 79  → STRIPE_PRICE_AED_MONTHLY
#   - Mony Pro / yearly recurring  / AED    AED 749 → STRIPE_PRICE_AED_YEARLY
#
# H.8 (revised post-H.7.3) reads NEXT_CURRENCY cookie + cadence
# param and selects the matching env via
# `STRIPE_PRICE_${CURRENCY}_${CADENCE}`.
STRIPE_PRICE_EUR_MONTHLY=price_...
STRIPE_PRICE_EUR_YEARLY=price_...
STRIPE_PRICE_USD_MONTHLY=price_...
STRIPE_PRICE_USD_YEARLY=price_...
STRIPE_PRICE_AED_MONTHLY=price_...
STRIPE_PRICE_AED_YEARLY=price_...

# ─── Stripe webhook (H.9) ────────────────────────────────────────
# Signing secret from Stripe Dashboard:
#   Developers → Webhooks → your endpoint → "Reveal signing secret"
# For local dev: Stripe CLI emits its own whsec_… on
#   `stripe listen --forward-to localhost:3000/api/stripe/webhook`
# Use that local secret in dev; the Dashboard one in production.
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Supabase service role (H.9, server-only) ────────────────────
# CRITICAL: this key bypasses Row-Level Security and can read /
# write any row in the database. Treat as a production secret.
#   - NEVER prefix with NEXT_PUBLIC_ — that would inline it into
#     the client bundle.
#   - NEVER import the admin client (`getSupabaseAdmin`) from a
#     Client Component.
#   - Get it from Supabase Dashboard → Project Settings → API →
#     "service_role" (under Project API keys).
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# ─── PostHog (analytics + feature flags) ─────────────────────────
# Same PostHog project the mobile app uses (Mony EU). Both NEXT_PUBLIC_
# values are safe to expose to the browser — they identify the project
# but cannot read or write data without further authorization.
#
# Web-side files reading these vars:
#   - lib/posthog.ts            (server-side feature flags via /decide)
#   - lib/posthog-client.ts     (legacy custom events via /capture)
#   - components/analytics/PostHogProvider.tsx (posthog-js SDK init)
#
# The mobile EXPO_PUBLIC_POSTHOG_API_KEY / EXPO_PUBLIC_POSTHOG_HOST
# pair holds the same values under the Expo-prefixed namespace. Both
# pairs are required when developing both surfaces locally.
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
