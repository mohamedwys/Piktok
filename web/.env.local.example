# Mony web — local dev environment example.
# Copy to `.env.local` and fill with the real values from your
# Supabase project (Dashboard → Settings → API).
#
# Both NEXT_PUBLIC_* values are safe to expose to the browser by
# design — they're the same anon credentials the mobile app reads
# from EXPO_PUBLIC_SUPABASE_URL / EXPO_PUBLIC_SUPABASE_ANON_KEY.
# RLS gates what the anon role can see; the service role key
# (NOT here) is what would be dangerous to expose.

NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>
