{
  "expo": {
    "name": "Pictok",
    "slug": "client",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "client",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.pictok.client",
      "supportsTablet": true,
      "buildNumber": "4",
      "requireFullScreen": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UISupportedInterfaceOrientations": ["UIInterfaceOrientationPortrait"],
        "UISupportedInterfaceOrientations~ipad": ["UIInterfaceOrientationPortrait", "UIInterfaceOrientationPortraitUpsideDown"],
        "NSCameraUsageDescription": "Pictok uses your camera so you can take photos and videos of items to list on the marketplace.",
        "NSMicrophoneUsageDescription": "Pictok uses your microphone when you record videos for your marketplace listings.",
        "NSPhotoLibraryUsageDescription": "Pictok accesses your photo library so you can pick existing photos to attach to your marketplace listings.",
        "NSPhotoLibraryAddUsageDescription": "Pictok saves photos and videos you capture in the app to your photo library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.pictok.client"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-video",
      [
        "expo-camera",
        {
          "cameraPermission": "Pictok uses your camera so you can take photos and videos of items to list on the marketplace.",
          "microphonePermission": "Pictok uses your microphone when you record videos for your marketplace listings.",
          "recordAudioAndroid": true,
          "barcodeScannerEnabled": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Pictok accesses your photo library so you can pick existing photos to attach to your marketplace listings."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-video",
      "expo-font",
      "expo-web-browser",
      "expo-localization",
      [
        "expo-notifications",
        {
          "color": "#FE2C55"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3bcee70c-5f94-474a-aebd-ce2ca085a75f"
      }
    }
  }
}
